{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/dist/$1"
        }
    ],
    "framework": "vite",
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/dist"
}